        "type": "object",
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "city": {
            "type": "string"
          },
          "starRating": {
            "type": "integer",
            "minimum": 0,
            "maximum": 5
          },
          "distanceToHaramM": {
            "type": "number",
            "minimum": 0
          },
          "nightlyNet": {
            "type": "object",
            "properties": {
              "amount": {
                "type": "integer"
              },
              "currency": {
                "type": "string",
                "enum": [
                  "EUR",
                  "PKR",
                  "SAR"
