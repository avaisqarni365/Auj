          "checkIn": {
            "type": "string"
          },
          "checkOut": {
            "type": "string"
          },
          "pax": {
            "type": "integer",
            "exclusiveMinimum": true,
            "minimum": 0
          },
          "starRating": {
            "anyOf": [
              {
                "type": "number",
                "enum": [
                  1
                ]
              },
              {
                "type": "number",
                "enum": [
                  2
