              },
              {
                "type": "number",
                "enum": [
                  3
                ]
              },
              {
                "type": "number",
                "enum": [
                  4
                ]
              },
              {
                "type": "number",
                "enum": [
                  5
                ]
              }
            ]
          }
        },
        "required": [
          "city",
          "checkIn",
          "checkOut",
          "pax"
        ],
        "additionalProperties": false
      },
