{
  "name": "auj",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "dev": "turbo run dev --filter=@auj/web",
    "dev:web": "turbo run dev --filter=@auj/web",
    "dev:all": "turbo run dev --concurrency=15",
    "gen:spec": "pnpm --filter @auj/contracts build && tsx scripts/gen-connector-spec.mts",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\""
  },
  "devDependencies": {
    "@auj/contracts": "workspace:*",
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "prettier": "^3.4.2",
    "sharp": "^0.35.1",
    "tsx": "^4.19.2",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5"
  }
}
