# Production env for infra/docker-compose.yml. Copy to infra/.env on the server and fill in.
# NEVER commit the real .env.

# Image to run (pushed by the deploy workflow)
WEB_IMAGE=ghcr.io/avaisqarni365/auj-web:latest
WEB_PORT=3000

# Domain + TLS (Caddy auto-HTTPS). Point a GoDaddy A record for `auj` at this server's IP.
DOMAIN=auj.codes-ai.uk
ACME_EMAIL=admin@codes-ai.uk
APP_ORIGIN=https://auj.codes-ai.uk

# Connector / supplier selection (mock until the real Saudi connector is certified)
CONNECTOR=mock
SUPPLIER=mock

# Payment acquirers — providers go LIVE only when their keys are set, else offline sandbox.
# EUR via Stripe; PKR via a Safepay/PayFast-style JSON gateway.
# STRIPE_SECRET_KEY=sk_live_xxx
# PKR_GATEWAY_URL=https://api.safepay.example
# PKR_GATEWAY_KEY=xxx

# Email notifications — log adapter by default; set these to send real email via a JSON API.
# EMAIL_API_URL=https://api.resend.com/emails
# EMAIL_API_KEY=xxx
# EMAIL_FROM=AUJ <no-reply@auj.example>

# Auth: seeded admin (change these!) + session
ADMIN_EMAIL=admin@auj.example
ADMIN_PASSWORD=change-me

# Postgres (datastore bound to 127.0.0.1 on the host — reach via SSH tunnel)
POSTGRES_USER=auj
POSTGRES_PASSWORD=change-me
POSTGRES_DB=auj
DATABASE_URL=postgresql://auj:change-me@postgres:5432/auj?schema=public

REDIS_URL=redis://redis:6379

# Object store (MinIO)
OBJECT_STORE_ACCESS_KEY=auj
OBJECT_STORE_SECRET_KEY=change-me
