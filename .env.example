# Active connector + supplier (mock in dev/test; real ones swapped in via env)
CONNECTOR=mock
SUPPLIER=mock

# Datastores (match docker-compose.yml)
DATABASE_URL=postgresql://auj:auj@localhost:5432/auj?schema=public
REDIS_URL=redis://localhost:6379

# S3-compatible object store (MinIO in dev)
OBJECT_STORE_ENDPOINT=http://localhost:9000
OBJECT_STORE_ACCESS_KEY=auj
OBJECT_STORE_SECRET_KEY=auj-secret
OBJECT_STORE_BUCKET=auj-docs

# Payments (placeholders — never commit real keys)
STRIPE_SECRET_KEY=
PKR_GATEWAY_KEY=

# Saudi partner (Wave C; gated)
SAUDI_PARTNER_BASE_URL=
SAUDI_PARTNER_AGENT_CODE=

# Server / tunnel secrets — NEVER put real values here. This file (.env.example) is committed to
# GitHub. Put real values ONLY in .env (git-ignored). Rotate anything that was ever committed/shared.
IONOS_SSH_PASSWORD=
DB_NAME=
DB_USER=
DB_PASSWORD=